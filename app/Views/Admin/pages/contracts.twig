{% block title %}Správa pojistných smluv - Administrace{% endblock %}
{% block headline %}Správa pojistných smluv - Administrace{% endblock %}

{% block content %}
<section class="contracts py-3">
  <h3>Správa pojistných smluv</h3>
  <input class="form-control my-3" id="searchInput" type="text" placeholder="Hledat...">
  <div class="d-flex gap-2 align-items-center my-3">
    <label for="sortColumn">Seřadit podle:</label>
    <select id="sortColumn" class="form-select w-25">
      <option value="id">ID</option>
      <option value="client">Klient</option>
      <option value="vehicle">Vozidlo</option>
      <option value="type">Typ pojištění</option>
      <option value="price">Cena</option>
      <option value="payment_state">Stav platby</option>
      <option value="valid_from">Platné od</option>
      <option value="valid_to">Platné do</option>
      <option value="notes">Poznámky</option>
    </select>

    <select id="sortDirection" class="form-select w-25">
      <option value="ASC">Vzestupně</option>
      <option value="DESC">Sestupně</option>
    </select>

    <button id="sortButton" class="btn btn-light">Seřadit</button>
  </div>

  <table class="table table-bordered table-striped">
    <thead>
      <tr>
        <th>ID</th>
        <th>Klient</th>
        <th>Vozidlo</th>
        <th>Typ pojištění</th>
        <th>Cena</th>
        <th>Stav platby</th>
        <th>Platné od</th>
        <th>Platné do</th>
        <th>Poznámky</th>
        <th>Akce</th>
      </tr>
    </thead>
    <tbody id="clientsTable"></tbody>
  </table>
  <button class="btn btn-primary" id="loadMore">Načíst další</button>

  <div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userEditModal" data-bs-backdrop="static"
    aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="userEditModal">Upravit záznam</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form id="user_edit_form" style="display: contents" method='POST'>
          <div class="modal-body" id="rowData">
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Zavřít</button>
            <input type="submit" value="Uložit změny" data-bs-dismiss="modal" class="btn btn-success" />
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script src="/public/assets/js/admin/contract/contract_table.js"></script>
<script src="/public/assets/js/admin/contract/contract_modal_display.js"></script>
<script src="/public/assets/js/admin/contract/contract_form_send.js"></script>
<script src="/public/assets/js/admin/contract/contract_delete.js"></script>

{% endblock %}