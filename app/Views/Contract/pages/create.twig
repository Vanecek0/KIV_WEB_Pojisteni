{% block title %}Nové pojištění - Klientský portál{% endblock %}

{% block content %}
<form id="new-contract" class="multistep-form" method="post" enctype="multipart/form-data">
    <div class="form-header d-flex mb-5">
        <span class="stepIndicator">Vstupní údaje</span>
        <span class="stepIndicator">Údaje o vozidle</span>
        <span class="stepIndicator">Smlouva</span>
    </div>
    <div class="container">
        <div class="step">
            <fieldset id="insurer" class="mb-4 mt-2">
                <h3>Údaje pojistníka</h3>

                <input type="hidden" name="client_id" value="{{user.id}}">

                <label for="firstname" class="form-label">Jméno</label>
                <input type="text" placeholder="Např.: Jan" value="{{user.firstname}}" id="firstname" name="firstname" class="form-control mb-4" disabled>

                <label for="lastname" class="form-label">Příjmení</label>
                <input type="text" placeholder="Např.: Novák" value="{{user.lastname}}" id="lastname" name="lastname" class="form-control mb-4" disabled>

                <label for="birth" class="form-label">Datum narození</label>
                <input type="date" id="birth" name="birth" value="{{user.birth}}" class="form-control mb-4" disabled>

                <label for="birth-number" class="form-label">Rodné číslo</label>
                <input type="text" placeholder="Např.: 739028/5163" value="{{user.birth_number}}" id="birth-number" name="birth-number"
                    class="form-control mb-4" disabled>

                <label for="phone-number" class="form-label">Telefon</label>
                <div class="input-group mb-4">
                    <span class="input-group-text" id="basic-addon1">+420</span>
                    <input type="text" placeholder="Např.: 123 456 789" value="{{user.phone}}" id="phone-number" name="phone-number"
                        aria-describedby="basic-addon1" class="form-control" disabled>
                </div>

                <label for="email" class="form-label">Emailová adresa *</label>
                <input type="text" placeholder="Např.: jan.novak@example.com" value="{{user.email}}" id="email" name="email"
                    class="form-control mb-4" disabled>

                <label for="city" class="form-label">Město/obec</label>
                <input type="text" placeholder="Např.: Praha 7-Holešovice" value="{{user.city}}" id="city" name="city"
                    class="form-control mb-4" disabled>

                <label for="street" class="form-label">Ulice</label>
                <input type="text" placeholder="Např.: Dukelských Hrdinů 906/48" value="{{user.street}}" id="street" name="street"
                    class="form-control mb-4" disabled>

                <label for="psc" class="form-label">PSČ</label>
                <input type="text" placeholder="Např.: 170 00" id="psc" name="psc" value="{{user.psc}}" 
                    class="form-control mb-4" disabled>

            </fieldset>
        </div>
        <div class="step">
            <fieldset id="vehicle" class="mb-4 mt-2">
                <h3>Moje vozidlo</h3>

                <label for="car_select" class="form-label mt-2">Vyberte vozidlo</label>
                <select class="selectpicker form-control mb-2" name="car_select" data-live-search="true" data-size="8">
                    <option value=""></option>
                    {% for v in user_vehicles %}
                        <option data-tokens="{{ v.spz }} - {{ v.brand }} {{ v.model }}"
                            value="{{ v.id }}">{{ v.spz }} - {{ v.brand }} {{ v.model }}
                        </option>
                    {% endfor %}
                </select>
                <p class="mt-2">nebo</p>
                <button class="btn btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapseExample" aria-expanded="false" aria-controls="collapseExample">
                    <i class="bi bi-plus-lg"></i><span>Přidat nové vozidlo</span>
                </button>

                <div class="collapse" id="collapseExample">
                <div class="radio-group d-flex gap-2 mb-3 mt-3">
                    <div
                        class="form-check vehicle-radio-input bg-light rounded d-flex justify-content-center align-items-center">
                        <label for="type" role="button"
                            class="form-check-label p-3 d-flex flex-row-reverse gap-2 justify-content-center align-items-center">
                            <span>Osobní vozidlo (do 3,5t)</span>
                            <i class="bi bi-car-front-fill fs-4"></i>
                            <input type="radio" id="type" value="type" name="type" class="form-check-input" checked>
                        </label>
                    </div>
                </div>
                <label for="vin" class="form-label">VIN vozidla</label>
                <input type="text" id="vin" name="vin" class="form-control mb-4">

                <label for="spz" class="form-label">SPZ vozidla</label>
                <input type="text" placeholder="Např.: 1A2 9875" id="spz" name="spz" class="form-control mb-4">

                <label for="car_model" class="form-label">Vozidlo</label>
                <select class="selectpicker form-control mb-4" name="car_model" data-live-search="true" data-size="8">
                    <option value=""></option>
                    {% for b in cars %}
                    <optgroup label="{{ b.make }}">
                        {% for m in b.models %}
                        <option data-tokens="{{ m.model }} {{ m.eng_power }}hp (r.v {{ m.year }})"
                            value='{"make":{{ b.make | json_encode }},"vehicle":[{{ m | json_encode }}]}'>{{ m.model }} {{ m.eng_power }}hp (r.v {{ m.year }})
                        </option>
                        {% endfor %}
                    </optgroup>
                    {% endfor %}
                </select>

                <label for="registration_date" class="form-label">Datum první registrace</label>
                <input type="date" id="registration_date" name="registration_date" class="form-control mb-4">

                <label for="images" class="form-label">Fotky vozidla</label>
                <input type="file" id="images" name="images[]" class="form-control mb-4" accept="image/*" multiple>
                </div>
            </fieldset>
        </div>
        <div class="step">
            <fieldset id="contract" class="mb-4 mt-2">
                <h3>Výběr pojištění</h3>

                <label for="valid_from" class="form-label">Datum počátku pojištění</label>
                <input type="date" id="valid_from" name="valid_from" class="form-control mb-4" required>

                <div class="d-flex gap-3 mb-4">
                    <div class="d-flex">
                        <label class="d-flex align-items-stretch">
                            <input type="radio" value='{"type":"KOMFORT","price":"6210"}' name="type_price" selected checked class="card-input-element" />

                            <div class="card card-default card-input">
                                <div class="card-header fw-bold">KOMFORT</div>
                                <div class="card-body">
                                    <p><i class="bi bi-check-lg"></i> Povinné ručení</p>
                                    <p><i class="bi bi-check-lg"></i> Právní poradenství</p>
                                    <p><i class="bi bi-check-lg"></i> Asistence</p>
                                    <p><i class="bi bi-check-lg"></i> Úrazové pojištění</p>
                                </div>
                                <span class="text-center fs-5 mb-2">6210 Kč/rok</span>
                                <span class="btn btn-primary">Vybrat</span>
                            </div>

                        </label>

                    </div>
                    <div class="d-flex">

                        <label class="d-flex align-items-stretch">
                            <input type="radio" value='{"type":"PLUS","price":"8250"}' name="type_price" selected checked class="card-input-element" />

                            <div class="card card-default card-input">
                                <div class="card-header fw-bold">PLUS</div>
                                <div class="card-body">
                                    <p><i class="bi bi-check-lg"></i> Povinné ručení</p>
                                    <p><i class="bi bi-check-lg"></i> Právní poradenství</p>
                                    <p><i class="bi bi-check-lg"></i> Asistence</p>
                                    <p><i class="bi bi-check-lg"></i> Úrazové pojištění</p>
                                    <p><i class="bi bi-check-lg"></i> Přírodní události</p>
                                    <p><i class="bi bi-check-lg"></i> Požár a výbuch</p>
                                    <p><i class="bi bi-check-lg"></i> Poškození zvířetem</p>
                                    <p><i class="bi bi-check-lg"></i> Rozšířená asistence</p>
                                </div>
                                <span class="text-center fs-5 mb-2">8250 Kč/rok</span>
                                <span class="btn btn-primary">Vybrat</span>
                            </div>

                        </label>

                    </div>
                    <div class="d-flex">

                        <label class="d-flex align-items-stretch">
                            <input type="radio" value='{"type":"EXTRA","price":"10350"}' name="type_price" class="card-input-element" />

                            <div class="card card-default card-input">
                                <div class="card-header fw-bold">EXTRA</div>
                                <div class="card-body">
                                    <p class="text-center">Všechny výhody pojištění Plus</p>
                                    <p><i class="bi bi-check-lg"></i> Krádež</p>
                                    <p><i class="bi bi-check-lg"></i> Skla</p>
                                    <p><i class="bi bi-check-lg"></i> Vandalismus</p>
                                </div>
                                <span class="text-center fs-5 mb-2">10350 Kč/rok</span>
                                <span class="btn btn-primary">Vybrat</span>
                            </div>
                        </label>

                    </div>
                    <div class="d-flex">

                        <label class="d-flex align-items-stretch">
                            <input type="radio" value='{"type":"MAX","price":"14580"}' name="type_price" class="card-input-element" />

                            <div class="card card-default card-input">
                                <div class="card-header fw-bold">MAX</div>
                                <div class="card-body">
                                    <p class="text-center">Všechny výhody pojištění Extra</p>
                                    <p><i class="bi bi-check-lg"></i> Havárie</p>
                                </div>
                                <span class="text-center fs-5 mb-2">14580 Kč/rok</span>
                                <span class="btn btn-primary">Vybrat</span>
                            </div>
                        </label>

                    </div>
                </div>

                <label for="notes" class="form-label">Doplňující informace</label>
                <textarea id="notes" name="notes" class="form-control mb-4"></textarea>

            </fieldset>
        </div>
        <p id="errorMessage" class="text-danger"></p>
        <div class="form-footer d-flex justify-content-between">
            <button type="button" class="btn btn-outline-primary btn-lg" id="prevBtn"
                onclick="nextPrev(-1)">Předchozí</button>
            <button type="button" class="btn btn-primary btn-lg" id="nextBtn" onclick="nextPrev(1)">Pokračovat</button>
            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">Odeslat</button>
        </div>
    </div>
</form>
<script src="/public/assets/js/portal/contract/contract_form_send.js"></script>
<script src="/public/assets/js/portal/multistep_form.js"></script>
<script src="/public/assets/js/portal/ares.js"></script>
{% endblock %}