{% block title %}Správa pojistných událostí - Administrace{% endblock %}
{% block headline %}Správa pojistných událostí - Administrace{% endblock %}

{% block content %}
<section class="contracts py-3">
  <h3>Správa pojistných událostí</h3>
  <input class="form-control my-3" id="searchInput" type="text" placeholder="Hledat...">
  <div class="d-flex gap-2 align-items-center my-3">
    <label for="sortColumn">Seřadit podle:</label>
    <select id="sortColumn" class="form-select w-25">
      <option value="id">ID</option>
      <option value="firstname">Jméno</option>
      <option value="lastname">Příjmení</option>
      <option value="phone">Telefon</option>
      <option value="username">Uživatelské jméno</option>
      <option value="email">Email</option>
      <option value="birth">Datum narození</option>
      <option value="birth_number">Rodné číslo</option>
      <option value="city">Město</option>
      <option value="street">Ulice</option>
      <option value="psc">PSČ</option>
      <option value="role">Role</option>
    </select>

    <select id="sortDirection" class="form-select w-25">
      <option value="ASC">Vzestupně</option>
      <option value="DESC">Sestupně</option>
    </select>

    <button id="sortButton" class="btn btn-light">Seřadit</button>
  </div>

  <table class="table table-bordered table-striped">
    <thead>
      <tr>
        <th>ID</th>
        <th>Smlouva ID</th>
        <th>Datum nehody</th>
        <th>Místo nehody</th>
        <th>Popis</th>
        <th>Odhadovaná škoda</th>
        <th>Jméno viníka</th>
        <th>Příjmení viníka</th>
        <th>Telefon viníka</th>
        <th>Stav hlášení</th>
        <th>Uzavřeno</th>
        <th>Poznámky</th>
        <th>Akce</th>
      </tr>
    </thead>
    <tbody id="insurancesTable"></tbody>
  </table>
  <button class="btn btn-primary" id="loadMore">Načíst další</button>

  <div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userEditModal" data-bs-backdrop="static"
    aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="userEditModal">Upravit záznam</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form id="insurance_edit_form" style="display: contents" method='POST'>
          <div class="modal-body" id="rowData">
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Zavřít</button>
            <input type="submit" value="Uložit změny" data-bs-dismiss="modal" class="btn btn-success" />
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script src="/public/assets/js/admin/insurance-events/insurance_table.js"></script>
<script src="/public/assets/js/admin/insurance-events/insurance_modal_display.js"></script>
<script src="/public/assets/js/admin/insurance-events/insurance_form_send.js"></script>
<script src="/public/assets/js/admin/insurance-events/insurance_delete.js"></script>

{% endblock %}