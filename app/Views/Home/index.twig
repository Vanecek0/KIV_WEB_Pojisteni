<article class="help-article container-fluid d-flex flex-column justify-content-center">
    <div class="headline d-flex flex-column justify-content-center align-items-center pt-4 ">
        <h2 class="text-white text-center fs-1">Jak Vám můžeme pomoci?</h2>
        <div class="underline rounded"></div>
    </div>
    <div class="container d-flex flex-wrap justify-content-around pt-5 pb-5">
        <a href="/insurance-report" class="btn d-flex flex-column fw-bolder fs-4"><i
                class="bi bi-ev-front-fill fs-1"></i>Hlášení
            škody</a>
        <a href="#faq" class="btn d-flex flex-column fw-bolder fs-4"><i
